AUTH_SECRET=replace-with-a-long-random-secret

AUTH_GITHUB_ID=your_github_oauth_app_client_id
AUTH_GITHUB_SECRET=your_github_oauth_app_client_secret

# 只允许这些 GitHub 用户登录，多个用英文逗号分隔
ALLOWED_GITHUB_LOGINS=your-github-username

# 可选：进一步绑定 GitHub 用户 ID，更稳
# 多个用英文逗号分隔
ALLOWED_GITHUB_IDS=12345678

# 可选：如果你要严格要求邮箱
# ALLOWED_EMAILS=you@example.com
